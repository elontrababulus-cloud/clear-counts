rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return isAuthed() && userRole() == 'admin';
    }

    function isStaff() {
      return isAuthed() && userRole() in ['admin', 'staff'];
    }

    function isClient() {
      return isAuthed() && userRole() == 'client';
    }

    function ownsDoc() {
      return isClient() && resource.data.clientUid == request.auth.uid;
    }

    // Validate that createdBy is the calling user's UID on create operations
    function validCreatedBy() {
      return !('createdBy' in request.resource.data)
        || request.resource.data.createdBy == request.auth.uid;
    }

    // Validate that updatedBy is the calling user's UID on update operations
    function validUpdatedBy() {
      return !('updatedBy' in request.resource.data)
        || request.resource.data.updatedBy == request.auth.uid;
    }

    // ─── Users ───────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthed() && (request.auth.uid == userId || isAdmin());
      // Allow self-creation; specific role-assignment logic is handled on first sign-in
      // via AuthContext, but rules ensure they can't self-promote.
      allow create: if isAuthed() && request.auth.uid == userId
        && validCreatedBy()
        && (
          !('role' in request.resource.data)
          || request.resource.data.role == 'staff'
          || isAdmin()
        );
      // Admin can update anyone; a user can update their own non-role fields
      allow update: if isAdmin()
        || (isAuthed()
            && request.auth.uid == userId
            && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
            && validUpdatedBy());
      allow delete: if isAdmin();
    }

    // ─── Clients ─────────────────────────────────────────────────────────────

    match /clients/{clientId} {
      allow read: if isStaff()
        || (isClient()
            && clientId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId);
      allow create: if isStaff() && validCreatedBy();
      allow update: if isStaff() && validUpdatedBy();
      allow delete: if isAdmin();

      match /contacts/{contactId} {
        allow read, write: if isStaff();
      }
    }

    // ─── Leads ───────────────────────────────────────────────────────────────

    match /leads/{leadId} {
      allow read: if isStaff();
      allow create: if isStaff() && validCreatedBy();
      allow update: if isStaff() && validUpdatedBy();
      allow delete: if isAdmin();

      match /activities/{activityId} {
        allow read, create: if isStaff();
        allow update, delete: if isAdmin();
      }
    }

    // ─── Quotes ──────────────────────────────────────────────────────────────

    match /quotes/{quoteId} {
      allow read: if isStaff() || ownsDoc();
      allow create: if isStaff() && validCreatedBy();
      allow update: if (isStaff() && validUpdatedBy())
        || (ownsDoc()
            && request.resource.data.status in ['accepted', 'declined']
            && request.resource.data.diff(resource.data)
                  .affectedKeys()
                  .hasOnly(['status', 'updatedAt', 'updatedBy']));
      allow delete: if isAdmin();
    }

    // ─── Invoices ────────────────────────────────────────────────────────────

    match /invoices/{invoiceId} {
      allow read: if isStaff() || ownsDoc();
      allow create: if isStaff() && validCreatedBy();
      allow update: if isStaff() && validUpdatedBy();
      allow delete: if isAdmin();
    }

    // ─── Payments — immutable after creation ─────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isStaff() || ownsDoc();
      allow create: if isStaff() && validCreatedBy();
      allow update, delete: if isAdmin();
    }

    // ─── Projects ────────────────────────────────────────────────────────────

    match /projects/{projectId} {
      allow read: if isStaff() || ownsDoc();
      allow create: if isStaff() && validCreatedBy();
      allow update: if isStaff() && validUpdatedBy();
      allow delete: if isAdmin();

      match /tasks/{taskId} {
        allow read: if isStaff()
          || (isClient()
              && get(/databases/$(database)/documents/projects/$(projectId)).data.clientUid == request.auth.uid);
        allow create: if isStaff() && validCreatedBy();
        allow update: if isStaff() && validUpdatedBy();
        allow delete: if isAdmin();

        match /comments/{commentId} {
          allow read: if isStaff()
            || (isClient()
                && get(/databases/$(database)/documents/projects/$(projectId)).data.clientUid == request.auth.uid);
          allow create: if isStaff() && validCreatedBy();
          allow update: if (isAdmin() || (isStaff() && resource.data.authorId == request.auth.uid))
            && validUpdatedBy();
          allow delete: if isAdmin()
            || (isStaff() && resource.data.authorId == request.auth.uid);
        }
      }
    }

    // ─── Company Settings ─────────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read: if isAuthed();
      // Only admin can write settings — hard enforced server-side
      allow write: if isAdmin();
    }

    // ─── Notifications ────────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isStaff();
      allow update: if isAuthed()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['read']);
      allow delete: if isAdmin()
        || (isAuthed() && resource.data.userId == request.auth.uid);
    }

    // ─── Audit Log — server-written, admin-readable, append-only ─────────────

    match /auditLog/{logId} {
      // Only admins can read audit logs
      allow read: if isAdmin();
      // Cloud Functions (admin SDK) bypass rules — client writes allowed for
      // completeness but the function triggers are the primary source of truth
      allow create: if isAuthed()
        && validCreatedBy()
        && request.resource.data.keys().hasAll(['collection', 'docId', 'action', 'timestamp'])
        && request.resource.data.action in ['created', 'updated', 'deleted'];
      allow update, delete: if false;
    }

  }
}

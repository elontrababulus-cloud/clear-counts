rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if user is authenticated
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      // Direct email whitelist is more reliable for bootstrap/initial setup
      return isAuthed() && 
        request.auth.token.email in ['paulinexu6@gmail.com', 'techcesstechnology@gmail.com'];
    }

    match /settings/{allPaths=**} {
      // All logged in users can see company logos/branding
      allow read: if isAuthed();
      // Only admins can update company branding
      allow write: if isAdmin();
    }

    match /clients/{clientId}/{allPaths=**} {
      // Staff can manage client documents
      allow read, write: if isAuthed(); 
    }

    match /users/{userId}/{allPaths=**} {
      // Users can manage their own profile photos
      allow read: if isAuthed();
      allow write: if isAuthed() && request.auth.uid == userId;
    }

    match /invoices/{invoiceId}/{allPaths=**} {
      // Staff can manage generated invoices
      allow read, write: if isAuthed();
    }

    match /quotes/{quoteId}/{allPaths=**} {
      // Staff can manage generated quotes
      allow read, write: if isAuthed();
    }
  }
}
